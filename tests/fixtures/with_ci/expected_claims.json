{
  "description": "Expected claims from CI fixture",
  "claims": [
    {
      "claim_type": "validated-command",
      "content_pattern": "^pytest$",
      "required": true
    },
    {
      "claim_type": "validated-command",
      "content_pattern": "ruff check",
      "required": true
    },
    {
      "claim_type": "validated-command",
      "content_pattern": "^pyright$",
      "required": true
    },
    {
      "claim_type": "validated-command",
      "content_pattern": "make test",
      "required": true
    },
    {
      "claim_type": "validated-command",
      "content_pattern": "make lint",
      "required": true
    },
    {
      "claim_type": "environment-prerequisite",
      "content_pattern": "Python >=3\\.12",
      "required": true
    },
    {
      "claim_type": "environment-prerequisite",
      "content_pattern": "node >=18",
      "required": true
    },
    {
      "claim_type": "environment-prerequisite",
      "content_pattern": "postgres",
      "required": false
    },
    {
      "claim_type": "environment-prerequisite",
      "content_pattern": "redis",
      "required": false
    },
    {
      "claim_type": "conflict",
      "content_pattern": "version conflict",
      "required": false
    }
  ]
}
